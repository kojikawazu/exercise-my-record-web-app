# このファイルをコピーして front/.env.local を作成してください:
#   cp .env.example .env.local
# ここに列挙した変数がアプリで実際に使用される環境変数の正（Single Source）です。

# --- Supabase（必須）---
# Supabase プロジェクトの Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Database（必須）---
# Supabase の接続文字列（Settings > Database）。未設定時は API が 503 を返すフォールバック動作
DATABASE_URL=

# --- 認証（必須）---
# 管理者として許可するメールアドレス（このアドレスのみ管理操作が可能）
ADMIN_EMAIL=

# --- App ---
# 本番/プレビューのサイト URL（OAuth リダイレクト等に使用）
NEXT_PUBLIC_SITE_URL=

# --- E2E テスト（任意・開発時のみ）---
# 認証をバイパスして E2E を実行するためのサーバー専用フラグ。
# 通常は手動設定不要（playwright.config.ts が `E2E_BYPASS=1 pnpm dev` で自動付与）。
# NODE_ENV=production では無効。
# E2E_BYPASS=1

# 注: Google OAuth のクライアント ID/Secret はアプリの環境変数ではなく
#     Supabase ダッシュボード（Authentication > Providers > Google）で設定します。
